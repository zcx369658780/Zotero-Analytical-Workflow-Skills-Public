{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scholartrace/scholartrace_case_bundle.schema.json",
  "title": "ScholarTrace Case Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "title",
    "educational_scenario",
    "source_provenance",
    "sources",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "case_id": {
      "$ref": "#/$defs/stableId"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "educational_scenario": {
      "type": "string",
      "minLength": 1
    },
    "source_provenance": {
      "$ref": "#/$defs/sourceProvenance"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,63}$"
    },
    "sourceProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "synthetic_independently_written",
        "reuse_status",
        "authoring_method",
        "creation_date",
        "license_reuse_note",
        "prohibited_content_review"
      ],
      "properties": {
        "synthetic_independently_written": {
          "const": true
        },
        "reuse_status": {
          "const": "project-authored-synthetic"
        },
        "authoring_method": {
          "type": "string",
          "minLength": 1
        },
        "creation_date": {
          "type": "string",
          "format": "date"
        },
        "license_reuse_note": {
          "type": "string",
          "minLength": 1
        },
        "prohibited_content_review": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "copied_source_passages",
            "private_zotero_content",
            "copyrighted_pdf_content",
            "purchased_data",
            "unpublished_research",
            "personal_data"
          ],
          "properties": {
            "copied_source_passages": {
              "const": false
            },
            "private_zotero_content": {
              "const": false
            },
            "copyrighted_pdf_content": {
              "const": false
            },
            "purchased_data": {
              "const": false
            },
            "unpublished_research": {
              "const": false
            },
            "personal_data": {
              "const": false
            }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "text",
        "locator",
        "limitations"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/stableId"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string",
          "pattern": "^synthetic://[a-z0-9_/]+$"
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "fixture_id",
        "text"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/stableId"
        },
        "fixture_id": {
          "$ref": "#/$defs/stableId"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

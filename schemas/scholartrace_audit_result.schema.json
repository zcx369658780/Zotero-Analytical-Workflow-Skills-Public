{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scholartrace/scholartrace_audit_result.schema.json",
  "title": "ScholarTrace Audit Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "case_id",
    "deterministic_policy_version",
    "execution",
    "provenance_summary",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "tool_version": {
      "type": "string",
      "pattern": "^0\\.1\\.[0-9]+$"
    },
    "case_id": {
      "$ref": "#/$defs/stableId"
    },
    "deterministic_policy_version": {
      "const": "scholartrace-policy-0.1.0"
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only_inputs",
        "no_overwrite"
      ],
      "properties": {
        "read_only_inputs": {
          "const": true
        },
        "no_overwrite": {
          "const": true
        }
      }
    },
    "provenance_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "synthetic_independently_written"
      ],
      "properties": {
        "synthetic_independently_written": {
          "const": true
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/auditClaim"
      }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,63}$"
    },
    "verdict": {
      "enum": [
        "supported",
        "partially_supported",
        "unsupported",
        "overstated",
        "unverifiable"
      ]
    },
    "citedSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "locator"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/stableId"
        },
        "locator": {
          "type": "string",
          "pattern": "^synthetic://[a-z0-9_/]+$"
        }
      }
    },
    "auditClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "fixture_id",
        "claim_text",
        "verdict",
        "cited_sources",
        "rationale",
        "missing_or_altered_qualifiers",
        "deterministic_rule_flags",
        "policy_trace",
        "unresolved_questions",
        "human_review_reason",
        "human_verified"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/stableId"
        },
        "fixture_id": {
          "$ref": "#/$defs/stableId"
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "cited_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/citedSource"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "missing_or_altered_qualifiers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deterministic_rule_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_trace": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "unresolved_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_review_reason": {
          "type": "string",
          "minLength": 1
        },
        "human_verified": {
          "const": false
        }
      }
    }
  }
}
